[Unit]
Description=LUHKAS world LanceDB compaction (daily maintenance)
After=vault-runtime.service
Wants=vault-runtime.service

[Service]
Type=oneshot
WorkingDirectory=%h/luhkas/vault
ExecStart=/usr/bin/python3 -u -m world.compact
Environment=PYTHONUNBUFFERED=1
TimeoutStartSec=4h
# Don't fail loud — if optimize hits a transient issue we'll retry tomorrow.
SuccessExitStatus=0 1

[Install]
WantedBy=default.target
