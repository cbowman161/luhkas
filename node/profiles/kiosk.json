{
  "node_id": "kiosk",
  "modules": [
    "camera_node",
    "audio_node",
    "display_node"
  ],
  "display": {
    "rotation": "right"
  },
  "extra_units": [
    "luhkas"
  ],
  "services": {
    "vision": {
      "env": {
        "SCOUT_HEF_PATH": "/usr/share/hailo-models/yolov8m_h10.hef",
        "SCOUT_POSE_ENABLED": "0",
        "SCOUT_SEARCH_ENABLED": "0",
        "SCOUT_WHEEL_ENABLED": "0",
        "SCOUT_VAULT_MEMORY_ENABLED": "1",
        "SCOUT_VAULT_MEMORY_URL": "http://luhkas-vault.local:7000",
        "CAMERA_TRANSFORM_180": "1"
      }
    },
    "display": {
      "env": {
        "DISPLAY_PORT": "5006"
      }
    }
  },
  "sync": {
    "host": "100.81.45.83",
    "_comment": "Tailscale 100.x IP — stable for the device's lifetime in this tailnet, no DHCP reservation needed. Bypasses mDNS resolution (which on this network goes through Tailscale anyway). Requires Tailscale up on both ends; if tailscaled is down on the node, fall back to LAN IP 192.168.4.57.",
    "_tailscale_host": "luhkas-kiosk.local",
    "_lan_host": "192.168.4.57"
  }
}
