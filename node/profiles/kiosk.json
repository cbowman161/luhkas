{
  "node_id": "kiosk",
  "modules": [
    "camera_node",
    "audio_node",
    "display_node"
  ],
  "display": {
    "rotation": "right"
  },
  "extra_units": [
    "luhkas"
  ],
  "services": {
    "vision": {
      "env": {
        "SCOUT_HEF_PATH": "/usr/share/hailo-models/yolov8m_h10.hef",
        "SCOUT_POSE_ENABLED": "0",
        "SCOUT_SEARCH_ENABLED": "0",
        "SCOUT_WHEEL_ENABLED": "0",
        "SCOUT_VAULT_MEMORY_ENABLED": "1",
        "SCOUT_VAULT_MEMORY_URL": "http://luhkas-vault.local:7000",
        "CAMERA_TRANSFORM_180": "1"
      }
    },
    "display": {
      "env": {
        "DISPLAY_PORT": "5006"
      }
    }
  },
  "sync": {
    "host": "192.168.4.57",
    "_comment": "LAN IP, not luhkas-kiosk.local mDNS, so autosync survives Tailscale SSH session-check gating AND tailscaled outages. Reserve this IP on the router. Tailnet hostname still works for human ssh.",
    "_tailscale_host": "luhkas-kiosk.local"
  }
}
