[Unit]
Description=LUHKAS audio button watcher ({NODE_ID})
After=network.target {NODE_ID}-audio.service
Wants={NODE_ID}-audio.service
{EXTRA_UNIT}
StartLimitIntervalSec=0

[Service]
Type=simple
WorkingDirectory={NODE_DIR}
Environment=LUHKAS_NODE_ID={NODE_ID}
Environment=AUDIO_BUTTON_GPIO=23
Environment=AUDIO_MUTE_URL=http://127.0.0.1:5004/mute
{EXTRA_ENV}
ExecStart=/usr/bin/python3 -u audio_node/button_watcher.py
Restart=always
RestartSec=3

[Install]
WantedBy=default.target
