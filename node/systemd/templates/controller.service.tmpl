[Unit]
Description=LUHKAS Gamepad Controller ({NODE_ID})
After={NODE_ID}-robot-api.service
{EXTRA_UNIT}
StartLimitIntervalSec=0

[Service]
Type=simple
WorkingDirectory={NODE_DIR}
Environment=LUHKAS_NODE_ID={NODE_ID}
{EXTRA_ENV}
ExecStart={NODE_DIR}/scripts/start_controller.sh
Restart=on-failure
RestartSec=5

[Install]
WantedBy=default.target
